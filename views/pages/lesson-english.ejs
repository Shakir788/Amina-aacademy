<!DOCTYPE html>
<html lang="fr" dir="ltr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Session <%= lessonId %> | English Mastery</title>
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@700;800&family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
    
    <style>
        :root {
            --primary: #4F46E5;
            --primary-hover: #4338CA;
            --success: #10B981;
            --warning: #F59E0B;
            --error: #EF4444;
            --bg-color: #F8FAFC;
            --card-bg: #FFFFFF;
            --text-main: #0F172A;
            --text-muted: #64748B;
        }

        body {
            background-color: var(--bg-color); font-family: 'Inter', sans-serif;
            margin: 0; padding: 0; color: var(--text-main);
            display: flex; flex-direction: column; min-height: 100vh;
        }

        nav {
            background: white; padding: 15px 5%; display: flex; justify-content: space-between;
            align-items: center; border-bottom: 2px solid #E2E8F0; position: sticky; top: 0; z-index: 100;
        }
        .nav-left { display: flex; align-items: center; gap: 15px; }
        .back-btn { color: var(--text-muted); text-decoration: none; font-size: 24px; font-weight: bold; }
        .progress-container { flex: 1; max-width: 300px; background: #E2E8F0; height: 12px; border-radius: 20px; overflow: hidden; margin: 0 20px; }
        .progress-bar { height: 100%; background: var(--success); width: 0%; transition: width 0.5s ease; }
        
        .stats-badge { display: flex; gap: 10px; }
        .streak-badge, .xp-badge { padding: 5px 12px; border-radius: 50px; font-weight: 700; font-size: 14px; display: flex; align-items: center; gap: 5px; }
        .streak-badge { background: #FEF3C7; color: #D97706; }
        .xp-badge { background: #E0E7FF; color: var(--primary); }

        .game-container {
            flex: 1; display: flex; flex-direction: column; align-items: center; justify-content: center; 
            padding: 20px; max-width: 600px; margin: 0 auto; width: 100%; box-sizing: border-box;
        }

        .flashcard {
            background: var(--card-bg); width: 100%; border-radius: 24px; padding: 25px 30px;
            box-shadow: 0 15px 35px rgba(0,0,0,0.05); border: 2px solid #E2E8F0;
            text-align: center; transition: all 0.3s ease; position: relative;
        }

        .status-badge {
            position: absolute; top: -15px; left: 50%; transform: translateX(-50%);
            background: var(--primary); color: white; padding: 5px 15px; border-radius: 20px;
            font-size: 12px; font-weight: 700; text-transform: uppercase; letter-spacing: 1px;
        }

        .exercise-img { width: 100%; height: 200px; object-fit: cover; border-radius: 16px; margin-bottom: 20px; display: none; }
        .exercise-img.active { display: block; }

        .pronunciation { font-size: 15px; color: var(--primary); background: #EEF2FF; display: inline-block; padding: 4px 12px; border-radius: 8px; margin-bottom: 10px; font-weight: 600; letter-spacing: 1px;}
        .target-sentence { font-family: 'Plus Jakarta Sans'; font-size: 32px; font-weight: 800; color: var(--text-main); margin: 0 0 20px; line-height: 1.3; }
        
        .translation-box { background: #F8FAFC; border: 1px solid #E2E8F0; padding: 15px; border-radius: 12px; margin-bottom: 25px; text-align: left; }
        .trans-row { display: flex; justify-content: space-between; margin-bottom: 8px; align-items: center; font-size: 15px; }
        .trans-row:last-child { margin-bottom: 0; }
        .lang-label { font-weight: 700; color: var(--text-muted); font-size: 12px; text-transform: uppercase; width: 60px; }
        .trans-fr { color: #334155; flex: 1; }
        .trans-darija { color: #0F766E; font-weight: 600; flex: 1; }
        .trans-ar { font-size: 18px; font-weight: 600; color: var(--text-main); text-align: right; flex: 1; font-family: 'Arial', sans-serif; }

        .grammar-hint { background: #FFFBEB; border-left: 4px solid var(--warning); padding: 15px; text-align: left; font-size: 14px; color: #92400E; border-radius: 0 8px 8px 0; margin-bottom: 25px; display: none; }
        .grammar-hint.active { display: block; }

        .action-area { display: flex; flex-direction: column; gap: 15px; width: 100%; }
        .btn-action { display: flex; align-items: center; justify-content: center; gap: 10px; width: 100%; padding: 18px; border-radius: 16px; font-size: 18px; font-weight: 700; border: none; cursor: pointer; transition: 0.3s; }
        .btn-listen { background: #F1F5F9; color: var(--text-main); border: 2px solid #CBD5E1; }
        .btn-listen:hover { background: #E2E8F0; }
        .btn-speak { background: var(--primary); color: white; box-shadow: 0 8px 20px rgba(79, 70, 229, 0.3); }
        .btn-speak:hover { background: var(--primary-hover); transform: translateY(-2px); }
        .btn-speak.listening { background: var(--error); animation: pulse 1.5s infinite; box-shadow: 0 8px 20px rgba(239, 68, 68, 0.4); }
        .btn-next { background: var(--success); color: white; display: none; box-shadow: 0 8px 20px rgba(16, 185, 129, 0.3); }
        .btn-next:hover { filter: brightness(1.1); transform: translateY(-2px); }

        .feedback-msg { margin-top: 15px; font-size: 15px; text-align: left; padding: 15px; border-radius: 12px; display: none; }
        .feedback-success { background: #D1FAE5; color: #065F46; display: block; text-align: center; font-weight: 700;}
        .feedback-error { background: #FEE2E2; color: #991B1B; display: block; }
        .feedback-error span { display: block; margin-top: 5px; }

        .repeat-tracker { display: flex; justify-content: center; gap: 10px; margin-bottom: 20px; }
        .dot { width: 12px; height: 12px; border-radius: 50%; background: #E2E8F0; }
        .dot.filled { background: var(--success); }

        .final-screen { display: none; text-align: center; }
        .final-icon { font-size: 80px; margin-bottom: 20px; }

        @keyframes pulse { 0% { transform: scale(1); } 50% { transform: scale(1.02); } 100% { transform: scale(1); } }
    </style>
</head>
<body>

    <nav>
        <div class="nav-left">
            <a href="/dashboard" class="back-btn">✕</a>
        </div>
        <div class="progress-container">
            <div class="progress-bar" id="progressBar"></div>
        </div>
        <div class="stats-badge">
            <div class="xp-badge">⭐ <span id="xpCounter">0</span> XP</div>
            <div class="streak-badge">🔥 <span>1</span></div>
        </div>
    </nav>

    <div class="game-container">
        
        <div class="flashcard" id="learningCard">
            <div class="status-badge" id="stepIndicator">1 / 5</div>
            
            <img src="" alt="Exercise context" class="exercise-img" id="exerciseImg">

            <div class="pronunciation" id="pronunciation">...</div>
            <div class="target-sentence" id="targetSentence">Loading...</div>
            
            <div class="translation-box" id="transBoxMain">
                <div class="trans-row" id="rowFr"><span class="lang-label">Fr</span> <span class="trans-fr" id="transFr">...</span></div>
                <div class="trans-row" id="rowDar"><span class="lang-label">Dar</span> <span class="trans-darija" id="transDarija">...</span></div>
                <div class="trans-row" id="rowAr"><span class="lang-label">Ar</span> <span class="trans-ar" dir="rtl" id="transAr">...</span></div>
            </div>

            <div class="grammar-hint" id="grammarHint">
                💡 <b>Indice:</b> <span id="hintText">...</span>
            </div>

            <div class="repeat-tracker" id="repeatTracker">
                <div class="dot" id="dot1"></div>
                <div class="dot" id="dot2"></div>
            </div>

            <div class="action-area">
                <button class="btn-action btn-listen" id="btnListen" onclick="playAudio()">🔊 Écouter</button>
                <button class="btn-action btn-speak" id="btnSpeak" onclick="startSpeaking()">🎤 Parler</button>
                <button class="btn-action btn-next" id="btnNext" onclick="nextCard()">Continue ➔</button>
            </div>

            <div class="feedback-msg" id="feedbackMsg"></div>
        </div>

        <div class="final-screen" id="finalScreen">
            <div class="final-icon">🏆</div>
            <h1 style="font-family: 'Plus Jakarta Sans'; font-size: 32px; margin-bottom: 10px;">Session Terminée!</h1>
            <p style="color: #64748B; font-size: 18px; margin-bottom: 30px;">+ <span id="finalXp">0</span> XP gagnés aujourd'hui.</p>
            <button class="btn-action btn-speak" style="max-width: 300px; margin: 0 auto;" onclick="finishSession()">
                Retour au Hub
            </button>
        </div>

    </div>

    <%- include('../partials/ai-coach') %>

    <script id="lesson-data" type="application/json">
        <%- JSON.stringify(lesson || {}) %>
    </script>
    
    <script src="https://cdn.jsdelivr.net/npm/canvas-confetti@1.6.0/dist/confetti.browser.min.js"></script>

    <script>
        // 🚀 Set Course Type Globally for the AI Coach Partial
        window.CURRENT_COURSE_TYPE = "<%= courseType %>";

        const rawData = JSON.parse(document.getElementById('lesson-data').textContent);
        const CURRENT_LESSON_ID = parseInt("<%= lessonId %>");

        let currentLessonData = null;
        if (rawData.lessons && Array.isArray(rawData.lessons)) {
            currentLessonData = rawData.lessons.find(l => l.id === CURRENT_LESSON_ID);
        } else {
            currentLessonData = rawData; 
        }

        if (!currentLessonData || !currentLessonData.exercises) {
            document.getElementById('targetSentence').innerText = "Erreur: Leçon introuvable.";
            document.getElementById('btnSpeak').style.display = 'none';
            document.getElementById('btnListen').style.display = 'none';
        } else {

            let exercises = currentLessonData.exercises || [];
            let currentIndex = 0;
            const totalCards = exercises.length;
            
            let totalXp = 0;
            let requiredSuccess = 2; 
            let currentSuccess = 0;

            const elPronunciation = document.getElementById('pronunciation');
            const elSentence = document.getElementById('targetSentence');
            const elTransFr = document.getElementById('transFr');
            const elTransDarija = document.getElementById('transDarija');
            const elTransAr = document.getElementById('transAr');
            const elHintBox = document.getElementById('grammarHint');
            const elHintText = document.getElementById('hintText');
            const elStepInd = document.getElementById('stepIndicator');
            const elProgressBar = document.getElementById('progressBar');
            const elFeedback = document.getElementById('feedbackMsg');
            const elXp = document.getElementById('xpCounter');
            const elImg = document.getElementById('exerciseImg');
            
            const rowFr = document.getElementById('rowFr');
            const rowDar = document.getElementById('rowDar');
            const rowAr = document.getElementById('rowAr');
            
            const btnListen = document.getElementById('btnListen');
            const btnSpeak = document.getElementById('btnSpeak');
            const btnNext = document.getElementById('btnNext');

            document.title = `${currentLessonData.title || 'Session'} | English Mastery`;

            const synth = window.speechSynthesis;
            let femaleVoice = null;

            function setFemaleVoice() {
                const voices = synth.getVoices();
                femaleVoice = voices.find(v => v.name.includes('Google UK English Female') || v.name.includes('Zira') || v.name.includes('Samantha') || v.name.includes('Female')) || voices.find(v => v.lang.startsWith('en-'));
            }
            
            synth.getVoices();
            if (speechSynthesis.onvoiceschanged !== undefined) {
                speechSynthesis.onvoiceschanged = setFemaleVoice;
            }

            window.playAudio = function() {
                if (synth.speaking) { synth.cancel(); }
                setTimeout(() => {
                    const utterThis = new SpeechSynthesisUtterance(exercises[currentIndex].en);
                    if (femaleVoice) { utterThis.voice = femaleVoice; }
                    utterThis.lang = 'en-US'; 
                    utterThis.rate = 0.85;
                    synth.speak(utterThis);
                }, 50);
            }

            const SpeechRecognition = window.SpeechRecognition || window.webkitSpeechRecognition;
            let recognition;
            
            if (SpeechRecognition) {
                recognition = new SpeechRecognition();
                recognition.lang = 'en-US';
                recognition.interimResults = false;

                recognition.onstart = function() {
                    btnSpeak.classList.add('listening');
                    btnSpeak.innerHTML = '🎧 Je vous écoute...';
                    elFeedback.style.display = 'none';
                };

                recognition.onresult = function(event) {
                    const speechResult = event.results[0][0].transcript.toLowerCase().trim();
                    const targetText = exercises[currentIndex].en.toLowerCase().replace(/[^\w\s\']/g, "").trim();
                    const cleanSpeech = speechResult.replace(/[^\w\s\']/g, "").trim();

                    let matched = false;
                    if (cleanSpeech.includes(targetText) || targetText.includes(cleanSpeech) || cleanSpeech === targetText) {
                        matched = true;
                    }
                    
                    if (!matched && exercises[currentIndex].variations) {
                        for(let variation of exercises[currentIndex].variations) {
                            let cleanVar = variation.toLowerCase().replace(/[^\w\s\']/g, "").trim();
                            if(cleanSpeech.includes(cleanVar) || cleanSpeech === cleanVar) {
                                matched = true; break;
                            }
                        }
                    }

                    if (matched) {
                        handleSuccess();
                    } else {
                        handleFailure(speechResult, exercises[currentIndex].en);
                    }
                };

                recognition.onerror = function() {
                    btnSpeak.classList.remove('listening'); btnSpeak.innerHTML = '🎤 Parler';
                    elFeedback.className = 'feedback-msg feedback-error';
                    elFeedback.innerHTML = "❌ Je n'ai pas bien entendu. Réessayez.";
                    elFeedback.style.display = 'block';
                };

                recognition.onend = function() { btnSpeak.classList.remove('listening'); };
            } else {
                alert("Navigateur non supporté pour la voix. Utilisez Chrome.");
                btnSpeak.style.display = 'none'; btnNext.style.display = 'flex';
            }

            window.startSpeaking = function() { if(recognition) { try { recognition.start(); } catch(e) {} } }

            function loadCard() {
                const currentEx = exercises[currentIndex];
                currentSuccess = 0; 
                updateDots();
                
                const activeImgUrl = currentEx.imageUrl || currentLessonData.imageUrl;
                if (activeImgUrl) {
                    elImg.src = activeImgUrl;
                    elImg.classList.add('active');
                } else {
                    elImg.classList.remove('active');
                }

                let pronunciationText = '';
                if(currentEx.pronunciation) {
                    if(typeof currentEx.pronunciation === 'object') pronunciationText = currentEx.pronunciation.simple || currentEx.pronunciation.fast;
                    else pronunciationText = currentEx.pronunciation;
                }

                elPronunciation.innerText = `🗣️ ${pronunciationText || '...'}`;
                elSentence.innerText = currentEx.en || '...';
                
                if(currentEx.fr) { elTransFr.innerText = currentEx.fr; rowFr.style.display = 'flex'; } 
                else { rowFr.style.display = 'none'; }
                
                if(currentEx.darija) { elTransDarija.innerText = currentEx.darija; rowDar.style.display = 'flex'; } 
                else { rowDar.style.display = 'none'; }
                
                if(currentEx.ar) { elTransAr.innerText = currentEx.ar; rowAr.style.display = 'flex'; } 
                else { rowAr.style.display = 'none'; }

                elStepInd.innerText = `${currentIndex + 1} / ${totalCards}`;
                
                const progress = (currentIndex / totalCards) * 100;
                elProgressBar.style.width = `${progress}%`;

                const hintTextData = currentEx.context || currentEx.practice || currentEx.hint;
                if (hintTextData) { elHintBox.classList.add('active'); elHintText.innerText = hintTextData; } 
                else { elHintBox.classList.remove('active'); }

                btnListen.style.display = 'flex'; btnSpeak.style.display = 'flex';
                btnSpeak.innerHTML = '🎤 Parler'; btnNext.style.display = 'none';
                elFeedback.style.display = 'none';
            }

            function updateDots() {
                document.getElementById('dot1').className = currentSuccess >= 1 ? 'dot filled' : 'dot';
                document.getElementById('dot2').className = currentSuccess >= 2 ? 'dot filled' : 'dot';
            }

            function handleSuccess() {
                currentSuccess++;
                updateDots();
                
                totalXp += 10;
                elXp.innerText = totalXp;

                elFeedback.className = 'feedback-msg feedback-success';
                
                if(currentSuccess < requiredSuccess) {
                    elFeedback.innerHTML = '🔥 Super ! Répétez encore une fois.';
                    btnSpeak.innerHTML = '🎤 Parler (Encore)';
                } else {
                    elFeedback.innerHTML = '🎉 Parfait !';
                    btnSpeak.style.display = 'none';
                    btnListen.style.display = 'none';
                    btnNext.style.display = 'flex';
                }
                elFeedback.style.display = 'block';
            }

            function handleFailure(whatTheySaid, target) {
                elFeedback.className = 'feedback-msg feedback-error';
                elFeedback.innerHTML = `
                    <b>Oups, presque!</b>
                    <span>🗣️ <b>Vous avez dit :</b> <i style="color:#475569;">"${whatTheySaid}"</i></span>
                    <span>🎯 <b>Correct :</b> <i style="color:#0F172A;">"${target}"</i></span>
                `;
                elFeedback.style.display = 'block';
                btnSpeak.innerHTML = '🎤 Réessayer';

                // 🚀 Call the AI Coach from the separate partial file!
                if (window.triggerAICoachError) {
                    window.triggerAICoachError(whatTheySaid, target);
                }
            }

            window.nextCard = function() {
                currentIndex++;
                if (currentIndex >= totalCards) {
                    elProgressBar.style.width = `100%`;
                    document.getElementById('learningCard').style.display = 'none';
                    document.getElementById('finalScreen').style.display = 'block';
                    document.getElementById('finalXp').innerText = totalXp;
                    
                    var duration = 3 * 1000;
                    var end = Date.now() + duration;
                    (function frame() {
                        confetti({ particleCount: 5, angle: 60, spread: 55, origin: { x: 0 }, colors: ['#4F46E5', '#10B981', '#F59E0B'] });
                        confetti({ particleCount: 5, angle: 120, spread: 55, origin: { x: 1 }, colors: ['#4F46E5', '#10B981', '#F59E0B'] });
                        if (Date.now() < end) { requestAnimationFrame(frame); }
                    }());
                } else {
                    loadCard();
                }
            }

            window.finishSession = async function() {
                const btn = document.querySelector('.final-screen .btn-speak');
                btn.innerHTML = '⏳ Sauvegarde...';
                btn.disabled = true;

                try {
                    const res = await fetch('/api/progress/complete', {
                        method: 'POST',
                        headers: { 'Content-Type': 'application/json' },
                        body: JSON.stringify({ lessonId: parseInt(CURRENT_LESSON_ID), courseType: CURRENT_COURSE_TYPE }) 
                    });
                    if (res.ok) { window.location.href = '/dashboard?t=' + new Date().getTime(); } 
                    else { alert("Erreur."); btn.innerHTML = 'Retour'; btn.disabled = false; }
                } catch (error) { alert("Erreur."); btn.innerHTML = 'Retour'; btn.disabled = false; }
            }

            window.onload = () => { loadCard(); };
        }
    </script>
</body>
</html>